import curses
import os
import time
from collections import deque

WIDTH = 40
HEIGHT = 20

class PCBCad:
    def __init__(self):
        self.resistor_map = {"A": 10.0, "B": 100.0, "C": 330.0, "D": 1000.0, "E": 10000.0}
        if os.path.exists("board_layout.txt"):
            self.load_board()
        else:
            self.clear_all_board()
        self.cursor_x = 0
        self.cursor_y = 0
        self.mode = "SELECT"
        self.current_char = "B"
        self.voltage_options = [1.5, 3.3, 5.0, 9.0, 12.0]
        self.v_idx = 2
        self.r_keys = ["A", "B", "C", "D", "E"]
        self.r_idx = 1
        self.sim_result = ""
        self.zoom_mode = False
        self.app_state = "CAD"
        self.machine_code_memory = ["00"] * 16
        self.prog_cursor = 0
        self.pc = 0
        self.cpu_power = False
        self.active_routes = set()
        self.anime_tick = 0

    @property
    def voltage(self):
        return self.voltage_options[self.v_idx]

    def clear_all_board(self):
        self.board = [['.' for _ in range(WIDTH)] for _ in range(HEIGHT)]
        self.active_routes.clear()
        self.cpu_power = False

    def init_colors(self):
        curses.start_color()
        curses.init_pair(1, curses.COLOR_RED, curses.COLOR_BLACK)
        curses.init_pair(2, curses.COLOR_BLUE, curses.COLOR_BLACK)
        curses.init_pair(3, curses.COLOR_GREEN, curses.COLOR_BLACK)
        curses.init_pair(4, curses.COLOR_YELLOW, curses.COLOR_BLACK)
        curses.init_pair(5, curses.COLOR_WHITE, curses.COLOR_BLACK)
        curses.init_pair(6, curses.COLOR_CYAN, curses.COLOR_BLACK)

    def get_color_attr(self, char, y, x):
        if self.cpu_power and (y, x) in self.active_routes and self.anime_tick % 2 == 0:
            return curses.color_pair(4) | curses.A_REVERSE | curses.A_BOLD
        if char == 'P': return curses.color_pair(1) | curses.A_BOLD
        elif char == 'G': return curses.color_pair(2) | curses.A_BOLD
        elif char in self.resistor_map: return curses.color_pair(3) | curses.A_BOLD
        elif char == '#': return curses.color_pair(4)
        else: return curses.color_pair(5)

    def run(self, stdscr):
        self.init_colors()
        stdscr.keypad(True)
        while True:
            stdscr.nodelay(True)
            key = stdscr.getch()
            self.anime_tick += 1
            time.sleep(0.05)
            if self.app_state == "CAD":
                self.draw_cad_screen(stdscr)
                if key != -1 and self.handle_cad_input(stdscr, key): break
            elif self.app_state == "PROGRAMMER":
                self.draw_programmer_screen(stdscr)
                if key != -1: self.handle_programmer_input(stdscr, key)

    def draw_cad_screen(self, stdscr):
        stdscr.clear()

        stdscr.addstr(0, 0, "=== PCB CAD & PC Data Exporter ===", curses.A_BOLD)
        p_status = "⚡ RUNNING" if self.cpu_power else "⏹️ STOPPED"
        stdscr.addstr(1, 0, f"Mode: {self.mode} | Zoom: {'ON' if self.zoom_mode else 'OFF'} | Power: {p_status}")
        stdscr.addstr(2, 0, "Controls: [M]Mode | [P]Power | [G]GND | [#]Wire | [A-E]Resistor | [D]Delete")
        stdscr.addstr(3, 0, "Tools:    [Z]Zoom | [C]Trace | [X]Reset | [S]Save | [U]Export PC Data | [Q]Quit")
        stdscr.addstr(4, 0, ">>> PRESS [O] TO ENTER PROGRAMMER MODE <<<", curses.color_pair(6) | curses.A_BOLD)
        stdscr.addstr(5, 0, "-" * (WIDTH + 2))

        if self.zoom_mode:
            sy = max(0, min(HEIGHT - 5, self.cursor_y - 2))
            sx = max(0, min(WIDTH - 10, self.cursor_x - 5))
            for y in range(5):
                stdscr.addstr(6 + (y * 2), 0, "|")
                for x in range(10):
                    char = self.board[sy + y][sx + x]
                    if self.cpu_power and (sy+y, sx+x) in self.active_routes and self.anime_tick % 2 == 0 and char == '#': char = '*'
                    stdscr.addstr(f" {char} ", self.get_color_attr(char, sy + y, sx + x))
                stdscr.addstr("|")
                stdscr.addstr(6 + (y * 2) + 1, 0, "|")
                for x in range(10):
                    char = self.board[sy + y][sx + x]
                    if self.cpu_power and (sy+y, sx+x) in self.active_routes and self.anime_tick % 2 == 0 and char == '#': char = '*'
                    stdscr.addstr(f" {char} ", self.get_color_attr(char, sy + y, sx + x))
                stdscr.addstr("|")
            stdscr.addstr(6 + 10, 0, "-" * 32)
            sc_y, sc_x = 6 + (self.cursor_y - sy) * 2, 1 + (self.cursor_x - sx) * 3 + 1
        else:
            for y in range(HEIGHT):
                stdscr.addstr(6 + y, 0, "|")
                for x in range(WIDTH):
                    char = self.board[y][x]
                    if self.cpu_power and (y, x) in self.active_routes and self.anime_tick % 2 == 0 and char == '#': char = '*'
                    stdscr.addstr(char, self.get_color_attr(char, y, x))
                stdscr.addstr("|")
            stdscr.addstr(6 + HEIGHT, 0, "-" * (WIDTH + 2))
            sc_y, sc_x = 6 + self.cursor_y, 1 + self.cursor_x

        res_offset = 8 + 10 if self.zoom_mode else 8 + HEIGHT
        stdscr.addstr(res_offset, 0, "[Simulation Output]")
        stdscr.addstr(res_offset + 1, 0, self.sim_result if self.sim_result else "Press [C] to trace.", curses.A_REVERSE)
        stdscr.move(sc_y, sc_x)
        stdscr.refresh()

    def handle_cad_input(self, stdscr, key):
        if key == ord('q') or key == ord('Q'): return True
        elif key == curses.KEY_UP and self.cursor_y > 0: self.cursor_y -= 1
        elif key == curses.KEY_DOWN and self.cursor_y < HEIGHT - 1: self.cursor_y += 1
        elif key == curses.KEY_LEFT and self.cursor_x > 0: self.cursor_x -= 1
        elif key == curses.KEY_RIGHT and self.cursor_x < WIDTH - 1: self.cursor_x += 1
        elif key in [ord('o'), ord('O')]: self.app_state = "PROGRAMMER"
        elif key in [ord('m'), ord('M')]: self.mode = "PIN" if self.mode == "SELECT" else "WIRE" if self.mode == "PIN" else "SELECT"
        elif key in [ord('p'), ord('P')]: self.current_char = "P"; self.mode = "PIN"
        elif key in [ord('g'), ord('G')]: self.current_char = "G"; self.mode = "PIN"
        elif key == ord('#'): self.current_char = "#"; self.mode = "WIRE"
        elif chr(key).upper() in self.resistor_map: self.current_char = chr(key).upper(); self.mode = "PIN"
        elif key in [ord('v'), ord('V')]: self.v_idx = (self.v_idx + 1) % len(self.voltage_options)
        elif key in [ord('e'), ord('E')]:
            self.r_idx = (self.r_idx + 1) % len(self.r_keys)
            self.current_char = self.r_keys[self.r_idx]
            self.mode = "PIN"
        elif key == ord('z') or key == ord('Z'): self.zoom_mode = not self.zoom_mode
        elif key in [ord('x'), ord('X')]:
            self.clear_all_board()
            self.sim_result = "Board cleared."
        elif key == ord(' '):
            if self.mode in ["PIN", "WIRE"]: self.board[self.cursor_y][self.cursor_x] = self.current_char
        elif key == ord('d') or key == ord('D'): self.board[self.cursor_y][self.cursor_x] = "."
        elif key == ord('s') or key == ord('S'): self.save_board()
        elif key in [ord('u'), ord('U')]: self.export_pc_data(stdscr) # 🆕 外部データ出力
        elif key == ord('c') or key == ord('C'): self.run_route_trace_simulation()
        return False

    # ─── 🆕 Windows/Mac用データエクスポート機能 ───
    def export_pc_data(self, stdscr):
        res_offset = 8 + 10 if self.zoom_mode else 8 + HEIGHT
        
        # 1. Excel/Numbers用 CSVファイル（部品表）の作成
        with open("pcb_bom.csv", "w") as f:
            f.write("Part_Type,X_Coordinate,Y_Coordinate,Value_Info\n")
            for y in range(HEIGHT):
                for x in range(WIDTH):
                    char = self.board[y][x]
                    if char in ['P', 'G'] or char in self.resistor_map:
                        val = self.resistor_map.get(char, "POWER")
                        f.write(f"{char},{x},{y},{val}\n")
                        
        # 2. 外部CAD用 簡易ガーバー形式（配線ベクトル情報）の作成
        with open("pcb_gerber_vector.txt", "w") as f:
            f.write("%======= REGION: WIRE VECTOR DATA FOR PC CAD =======%\n")
            f.write("G01* (Linear Interpolation Mode)\n")
            for y in range(HEIGHT):
                for x in range(WIDTH):
                    if self.board[y][x] == '#':
                        # ガーバー風のXY位置決めコード(D01=ペンを下ろして移動)を出力
                        f.write(f"X{x*100:04d}Y{y*100:04d}D01*\n")

        stdscr.addstr(res_offset + 3, 0, "EXPORT SUCCESS: 'pcb_bom.csv' & 'pcb_gerber_vector.txt' generated!", curses.A_BOLD | curses.color_pair(3))
        stdscr.refresh()
        curses.napms(1500)

